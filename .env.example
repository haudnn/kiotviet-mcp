# KiotViet API Credentials
KIOTVIET_CLIENT_ID=your_client_id_here
KIOTVIET_CLIENT_SECRET=your_client_secret_here
KIOTVIET_RETAILER=your_retailer_name_here

# Optional: Override base URLs
# KIOTVIET_BASE_URL=https://public.kiotapi.com
# KIOTVIET_TOKEN_URL=https://id.kiotviet.vn/connect/token

# Optional: F&B mode (uncomment to use F&B API)
# KIOTVIET_BASE_URL=https://publicfnb.kiotapi.com

# Transport mode: stdio (default) or http
# MCP_MODE=stdio
# MCP_PORT=3000
